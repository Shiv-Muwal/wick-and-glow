PORT=3000
ADMIN_API_KEY=change-me-in-production
JWT_SECRET=change-me-long-random-string
JWT_EXPIRE=7d

# MongoDB — Atlas example: mongodb+srv://USER:PASS@cluster.../wicknglow?appName=...
# (database name path mein zaroor ho, e.g. /wicknglow)
MONGODB_URI=mongodb://127.0.0.1:27017/wicknglow

# Cloudinary (image uploads; optional — bina inke upload routes 503)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Newsletter welcome email (Nodemailer). Gmail: App Password, spaces in EMAIL_PASS are OK.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
# Optional: "Wick & Glow <hello@yourdomain.com>"
EMAIL_FROM=
# Optional: show a real checkout code in the welcome email
# NEWSLETTER_WELCOME_CODE=WELCOME10
